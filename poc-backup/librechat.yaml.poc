# Definition of custom endpoints
endpoints:
  # Disable default endpoints - we only want Ollama
  openAI:
    disabled: true
  assistants:
    disabled: true
  anthropic:
    disabled: true
  google:
    disabled: true
  
  custom:
    # Ollama Local Instance
    - name: "Ollama"
      baseURL: "http://host.docker.internal:11434/v1"
      apiKey: "ollama"
      models:
        default: [
          "llama3.2:1b",
          "llama3.2:3b",
        ]
        fetch: true  # This will fetch available models from Ollama
      titleConvo: true
      titleModel: "llama3.2:1b"
      modelDisplayLabel: "Ollama"
